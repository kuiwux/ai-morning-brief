# ── 话题订阅 API ────────────────────────────────────────────────────────────


@app.route("/api/subscribe", methods=["POST"])
@require_token
def subscribe():
    """订阅话题
    Body: {user_id, topic}
    """
    try:
        data = request.get_json(force=True)
        user_id = data.get("user_id", "")
        topic = data.get("topic", "")

        if not user_id or not topic:
            return jsonify({"error": "user_id 和 topic 不能为空"}), 400

        conn = _get_db()
        cursor = conn.cursor()
        cursor.execute(
            "INSERT OR IGNORE INTO topic_subscriptions (user_id, topic) VALUES (?, ?)",
            (user_id, topic),
        )
        conn.commit()

        if cursor.rowcount > 0:
            logger.info(f"订阅成功: user_id={user_id}, topic={topic}")
            conn.close()
            return jsonify({"status": "ok", "message": f"已订阅「{topic}」"})
        else:
            conn.close()
            return jsonify({"status": "ok", "message": f"已订阅「{topic}」（重复订阅）"})

    except Exception as e:
        print(f"❌ /api/subscribe 错误: {e}", file=sys.stderr)
        logger.error(f"/api/subscribe error: {e}", exc_info=True)
        return jsonify({"error": "Internal server error"}), 500


@app.route("/api/subscriptions", methods=["GET"])
@require_token
def subscriptions_get():
    """读取用户订阅列表
    Query: user_id
    """
    try:
        user_id = request.args.get("user_id", "")

        if not user_id:
            return jsonify({"error": "user_id 不能为空"}), 400

        conn = _get_db()
        cursor = conn.cursor()
        cursor.execute(
            "SELECT topic, created_at FROM topic_subscriptions WHERE user_id=? ORDER BY created_at DESC",
            (user_id,),
        )
        rows = cursor.fetchall()
        conn.close()

        topics = [{"topic": row["topic"], "created_at": row["created_at"]} for row in rows]
        return jsonify({"user_id": user_id, "subscriptions": topics, "total": len(topics)})

    except Exception as e:
        print(f"❌ /api/subscriptions GET 错误: {e}", file=sys.stderr)
        logger.error(f"/api/subscriptions GET error: {e}", exc_info=True)
        return jsonify({"error": "Internal server error"}), 500


@app.route("/api/unsubscribe", methods=["POST"])
@require_token
def unsubscribe():
    """取消订阅话题
    Body: {user_id, topic}
    """
    try:
        data = request.get_json(force=True)
        user_id = data.get("user_id", "")
        topic = data.get("topic", "")

        if not user_id or not topic:
            return jsonify({"error": "user_id 和 topic 不能为空"}), 400

        conn = _get_db()
        cursor = conn.cursor()
        cursor.execute(
            "DELETE FROM topic_subscriptions WHERE user_id=? AND topic=?",
            (user_id, topic),
        )
        conn.commit()

        if cursor.rowcount > 0:
            logger.info(f"取消订阅: user_id={user_id}, topic={topic}")
            conn.close()
            return jsonify({"status": "ok", "message": f"已取消订阅「{topic}」"})
        else:
            conn.close()
            return jsonify({"status": "ok", "message": f"未找到订阅「{topic}」"})

    except Exception as e:
        print(f"❌ /api/unsubscribe 错误: {e}", file=sys.stderr)
        logger.error(f"/api/unsubscribe error: {e}", exc_info=True)
        return jsonify({"error": "Internal server error"}), 500


# ── 历史数据 API ───────────────────────────────────────────────────────────

# WORKDIR already defined above


@app.route("/api/history", methods=["GET"])
@require_token
def history():
    """
    返回最近 N 天的历史文章，支持播客模式加载多日数据。

    Query params:
        days (int): 返回最近 N 天的数据，默认 7

    扫描 WORKDIR 下 output_YYYY-MM-DD.json 文件，
    按日期倒序排列，每个文件的 articles 数组加上 date 字段后合并返回。

    返回格式:
    {
      "articles": [
        {
          "date": "2026-05-28",
          "title": "...",
          "category": "...",
          ...
        }
      ]
    }
    """
    try:
        days = request.args.get("days", 7, type=int)
        days = max(1, min(days, 90))  # 限制范围 1-90

        # 扫描日期化 JSON 文件
        pattern = os.path.join(WORKDIR, "output_*.json")
        json_files = glob.glob(pattern)

        if not json_files:
            return jsonify({"articles": [], "message": "暂无历史数据"})

        # 从文件名中提取日期并排序（倒序：最新的在前）
        dated_files = []
        for fpath in json_files:
            basename = os.path.basename(fpath)
            match = re.match(r"output_(\d{4}-\d{2}-\d{2})\.json", basename)
            if match:
                dated_files.append((match.group(1), fpath))

        dated_files.sort(key=lambda x: x[0], reverse=True)

        # 取最近 N 天
        dated_files = dated_files[:days]

        all_articles = []
        for date_str, fpath in dated_files:
            try:
                with open(fpath, "r", encoding="utf-8") as f:
                    data = json.load(f)
                # 提取 articles 数组，每条加上 date 字段
                for article in data.get("articles", []):
                    article_with_date = dict(article)
                    article_with_date["date"] = date_str
                    all_articles.append(article_with_date)
            except (json.JSONDecodeError, IOError) as e:
                print(f"⚠️ 读取 {fpath} 失败: {e}", file=sys.stderr)
                continue

        return jsonify({
            "articles": all_articles,
            "total": len(all_articles),
            "days_loaded": len(dated_files),
        })

    except Exception as e:
        print(f"❌ /api/history 错误: {e}", file=sys.stderr)
        return jsonify({"error": "Internal server error"}), 500


# ── 数据删除 API ────────────────────────────────────────────────────────────


@app.route("/api/account", methods=["DELETE"])
@require_token
def account_delete():
    """一键删除用户所有数据
    Body: {user_id}
    """
    try:
        data = request.get_json(force=True)
        user_id = data.get("user_id", "")

        if not user_id:
            return jsonify({"error": "user_id 不能为空"}), 400

        conn = _get_db()
        cursor = conn.cursor()

        tables = ["chat_history", "comments", "user_prefs", "favorites"]
        deleted = {}
        for table in tables:
            cursor.execute(f"DELETE FROM {table} WHERE user_id=?", (user_id,))
            deleted[table] = cursor.rowcount

        conn.commit()
        conn.close()

        logger.info(f"Account deleted for user_id={user_id}: {deleted}")
        return jsonify({"status": "ok", "message": "用户数据已全部删除", "deleted": deleted})

    except Exception as e:
        print(f"❌ /api/account DELETE 错误: {e}", file=sys.stderr)
        logger.error(f"/api/account DELETE error: {e}", exc_info=True)
        return jsonify({"error": "Internal server error"}), 500


@app.route("/api/chat/history", methods=["DELETE"])
@require_token
def chat_history_delete():
    """删除对话历史
    Body: {user_id, article_id}  # article_id 可选，不传则删全部
    """
    try:
        data = request.get_json(force=True)
        user_id = data.get("user_id", "")

        if not user_id:
            return jsonify({"error": "user_id 不能为空"}), 400

        conn = _get_db()
        cursor = conn.cursor()

        article_id = data.get("article_id", "")
        if article_id:
            cursor.execute(
                "DELETE FROM chat_history WHERE user_id=? AND article_id=?",
                (user_id, article_id),
            )
        else:
            cursor.execute(
                "DELETE FROM chat_history WHERE user_id=?",
                (user_id,),
            )

        deleted_count = cursor.rowcount
        conn.commit()
        conn.close()

        logger.info(f"Chat history deleted: user_id={user_id}, article_id={article_id or 'ALL'}, count={deleted_count}")
        return jsonify({"status": "ok", "deleted": deleted_count})

    except Exception as e:
        print(f"❌ /api/chat/history DELETE 错误: {e}", file=sys.stderr)
        logger.error(f"/api/chat/history DELETE error: {e}", exc_info=True)
        return jsonify({"error": "Internal server error"}), 500


# ── 安全响应头 ─────────────────────────────────────────────────────────────


@app.after_request
def add_security_headers(response):
    response.headers['X-Content-Type-Options'] = 'nosniff'
    response.headers['X-Frame-Options'] = 'DENY'
    return response


