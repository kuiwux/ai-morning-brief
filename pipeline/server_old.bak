# ── 对话持久化 API ────────────────────────────────────────────────────────────


def _get_db():
    """获取数据库连接（每次请求新建，确保线程安全）"""
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn


@app.route("/api/chat/save", methods=["POST"])
@require_token
def chat_save():
    """保存对话历史
    Body: {user_id, article_id, messages: [{role, content}]}
    """
    try:
        data = request.get_json(force=True)
        user_id = data.get("user_id", "")
        article_id = data.get("article_id", "")
        messages = data.get("messages", [])

        if not user_id or not article_id or not messages:
            return jsonify({"error": "user_id, article_id, messages 不能为空"}), 400

        conn = _get_db()
        cursor = conn.cursor()
        for msg in messages:
            cursor.execute(
                "INSERT INTO chat_history (user_id, article_id, role, content) VALUES (?, ?, ?, ?)",
                (user_id, article_id, msg.get("role", "user"), msg.get("content", "")),
            )
        conn.commit()
        conn.close()

        return jsonify({"status": "ok", "saved": len(messages)})

    except Exception as e:
        print(f"❌ /api/chat/save 错误: {e}", file=sys.stderr)
        logger.error(f"/api/chat/save error: {e}", exc_info=True)
        return jsonify({"error": "Internal server error"}), 500


@app.route("/api/chat/history", methods=["GET"])
@require_token
def chat_history():
    """读取对话历史
    Query: user_id, article_id
    """
    try:
        user_id = request.args.get("user_id", "")
        article_id = request.args.get("article_id", "")

        if not user_id or not article_id:
            return jsonify({"error": "user_id 和 article_id 不能为空"}), 400

        conn = _get_db()
        cursor = conn.cursor()
        cursor.execute(
            "SELECT role, content, created_at FROM chat_history WHERE user_id=? AND article_id=? ORDER BY id ASC",
            (user_id, article_id),
        )
        rows = cursor.fetchall()
        conn.close()

        messages = [{"role": row["role"], "content": row["content"], "created_at": row["created_at"]} for row in rows]
        return jsonify({"messages": messages, "total": len(messages)})

    except Exception as e:
        print(f"❌ /api/chat/history 错误: {e}", file=sys.stderr)
        logger.error(f"/api/chat/history error: {e}", exc_info=True)
        return jsonify({"error": "Internal server error"}), 500


@app.route("/api/prefs", methods=["POST"])
@require_token
def prefs_save():
    """保存用户偏好（UPSERT）
    Body: {user_id, category, preference}
    """
    try:
        data = request.get_json(force=True)
        user_id = data.get("user_id", "")
        category = data.get("category", "")
        preference = data.get("preference", "")

        if not user_id or not category or not preference:
            return jsonify({"error": "user_id, category, preference 不能为空"}), 400

        conn = _get_db()
        cursor = conn.cursor()
        cursor.execute(
            "INSERT INTO user_prefs (user_id, category, preference) VALUES (?, ?, ?) "
            "ON CONFLICT(user_id, category) DO UPDATE SET preference=excluded.preference",
            (user_id, category, preference),
        )
        conn.commit()
        conn.close()

        return jsonify({"status": "ok"})

    except Exception as e:
        print(f"❌ /api/prefs POST 错误: {e}", file=sys.stderr)
        logger.error(f"/api/prefs POST error: {e}", exc_info=True)
        return jsonify({"error": "Internal server error"}), 500


