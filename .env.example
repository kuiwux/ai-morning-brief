# Parro 环境变量
# 复制为 .env 文件，填入真实值后启动服务器

# ===== JWT =====
JWT_SECRET=your-32-char-random-secret-here

# ===== Google OAuth =====
# 去 https://console.cloud.google.com/apis/credentials 创建 OAuth 2.0 客户端 ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8899/api/auth/google/callback

# ===== Apple Sign-In =====
# 去 https://developer.apple.com/account/resources/identifiers 创建 Services ID
APPLE_CLIENT_ID=com.parro.xiaofuinfo
APPLE_TEAM_ID=W7BY6T84ZX
APPLE_KEY_ID=P22XMUK9Q6
APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey_P22XMUK9Q6.p8

# ===== WeChat OAuth（微信公众号网页授权）=====
# 去 https://mp.weixin.qq.com/ 开发者中心获取
WEIXIN_APPID=wx63bf49d44f1e3a03
WEIXIN_APPSECRET=your-weixin-appsecret
WEIXIN_REDIRECT_URI=https://api.parro.app/api/auth/wechat/callback

# ===== Alipay OAuth（支付宝第三方登录）=====
# 去 https://open.alipay.com/ 开放平台创建应用获取
ALIPAY_APP_ID=your-alipay-app-id
# 应用私钥（PKCS8 格式）
ALIPAY_PRIVATE_KEY=your-private-key
# 支付宝公钥
ALIPAY_PUBLIC_KEY=your-alipay-public-key
ALIPAY_REDIRECT_URI=https://api.parro.app/api/auth/alipay/callback
