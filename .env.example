# Parro 环境变量
# 复制为 .env 文件，填入真实值后启动服务器

# ===== JWT =====
JWT_SECRET=your-32-char-random-secret-here

# ===== Google OAuth =====
# 去 https://console.cloud.google.com/apis/credentials 创建 OAuth 2.0 客户端 ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8899/api/auth/google/callback

# ===== Apple Sign-In =====
# 去 https://developer.apple.com/account/resources/identifiers 创建 Services ID
APPLE_CLIENT_ID=com.parro.xiaofuinfo
APPLE_TEAM_ID=W7BY6T84ZX
APPLE_KEY_ID=P22XMUK9Q6
APPLE_PRIVATE_KEY_PATH=/path/to/AuthKey_P22XMUK9Q6.p8
