# ===== Parro 生产环境变量模板 =====
# 复制为 .env 并填入真实值

# ===== JWT 认证 =====
JWT_SECRET=change-me-to-a-random-64-char-string

# ===== Google OAuth =====
# 从 https://console.cloud.google.com/apis/credentials 获取
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=https://api.parro.app/api/auth/google/callback

# ===== Apple Sign-In =====
# Team ID + Key ID 从 App Store Connect 获取，p8 从 Certificates 下载
APPLE_CLIENT_ID=com.parro.xiaofuinfo
APPLE_TEAM_ID=W7BY6T84ZX
APPLE_KEY_ID=P22XMUK9Q6
APPLE_PRIVATE_KEY_PATH=/app/secrets/AuthKey_P22XMUK9Q6.p8

# ===== DeepSeek AI =====
DEEPSEEK_API_KEY=sk-xxx

# ===== 微信 =====
WEIXIN_APPID=wx63bf49d44f1e3a03
WEIXIN_APPSECRET=xxx
WEIXIN_REDIRECT_URI=https://api.parro.app/api/auth/wechat/callback

# ===== 支付宝 =====
ALIPAY_APP_ID=xxx
# 应用私钥（PKCS8 格式，-----BEGIN PRIVATE KEY-----）
ALIPAY_PRIVATE_KEY=xxx
# 支付宝公钥
ALIPAY_PUBLIC_KEY=xxx
ALIPAY_REDIRECT_URI=https://api.parro.app/api/auth/alipay/callback

# ===== Stripe 支付（可选）=====
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===== 网络代理 =====
https_proxy=http://172.23.80.1:7890

# ===== 服务配置 =====
FLASK_PORT=8899
FLASK_ENV=production
